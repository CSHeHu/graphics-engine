{
  "config": {
    "windowTitle": "LearnOpenGL",
    "opengl": {
      "contextVersionMajor": 3,
      "contextVersionMinor": 3
    },
    "cameraDefaults": {
      "yaw": -90.0,
      "pitch": 0.0,
      "speed": 2.5,
      "sensitivity": 0.1,
      "zoom": 45.0,
      "position": [0.0, 5.0, 3.0]
    },
    "assets": {
      "scenesPath": "assets/scenes",
      "meshesPath": "assets/meshes",
      "shadersPath": "assets/shaders"
    },
    "input": {
      "cameraControlsEnabled": true,
      "escape": 256,
      "moveForward": 87,
      "moveBackward": 83,
      "moveLeft": 65,
      "moveRight": 68,
      "moveUp": 69,
      "moveDown": 81,
      "toggleCameraMode": 67,
      "toggleInfoOverlay": 73,
      "togglePause": 80,
      "stepTimeBackward": 263,
      "stepTimeForward": 262
    },
    "rendering": {
      "positionNormalStride": 6,
      "maxLightSources": 8,
      "nearPlane": 0.1,
      "farPlane": 100.0,
      "depthTestEnabled": true,
      "blendEnabled": true
    }
  },
  "registry": [
    {
      "id": "Basic",
      "file": "assets/scenes/basic.scene.json"
    },
    {
      "id": "Alternate",
      "file": "assets/scenes/alternate.scene.json"
    }
  ],
  "cycle": [
    {
      "id": "Basic",
      "durationSeconds": 30
    }
  ],
  "ui": {
    "window": {
      "mode": "Windowed",
      "width": 1920,
      "height": 1080,
      "cursorCaptured": true,
      "vsyncEnabled": false
    },
    "infoOverlay": {
      "enabled": true,
      "fontPath": "assets/fonts/Arial.ttf",
      "vertexShaderPath": "assets/shaders/text.vs",
      "fragmentShaderPath": "assets/shaders/text.fs",
      "x": 10.0,
      "y": 700.0,
      "scale": 0.2,
      "lineSpacing": 10.0,
      "stats": ["fps", "sceneName", "time", "objects", "shaders"]
    }
  }
}
